{
  "name": "ezlet-monorepo",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "cd packages/ezlet && bun run build",
    "dev": "cd apps/site && bun run dev",
    "site:dev": "cd apps/site && bun run dev",
    "lint": "cd packages/ezlet && bun run lint && cd ../../apps/site && bun run lint",
    "test": "cd packages/ezlet && bun run test",
    "typecheck": "cd packages/ezlet && bun run typecheck && cd ../../apps/site && bun run typecheck",
    "site:build": "cd apps/site && bun run build",
    "site:preview": "cd apps/site && bun run preview"
  }
}
