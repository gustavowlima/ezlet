{
  "name": "island-toast",
  "version": "0.0.0",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "private": true,
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "sideEffects": [
    "*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": {
      "default": "./dist/styles.css"
    }
  },
  "scripts": {
    "build": "tsdown && cp src/styles/island-toast.css dist/styles.css",
    "check": "biome check .",
    "dev": "bun --hot playground/server.ts",
    "format": "biome check --write .",
    "lint": "biome check .",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@testing-library/react": "^16.3.2",
    "@types/bun": "latest",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "happy-dom": "^20.10.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsdown": "^0.22.3",
    "typescript": "^5"
  },
  "peerDependencies": {
    "react": "^18.3.0 || ^19.0.0",
    "react-dom": "^18.3.0 || ^19.0.0"
  },
  "dependencies": {
    "motion": "^12.42.0"
  }
}
