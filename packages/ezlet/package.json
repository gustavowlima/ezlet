{
  "name": "ezlet",
  "version": "1.0.0",
  "description": "Toast library for React.",
  "license": "MIT",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "homepage": "https://github.com/gustavowlima/ezlet#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gustavowlima/ezlet.git"
  },
  "bugs": {
    "url": "https://github.com/gustavowlima/ezlet/issues"
  },
  "keywords": [
    "react",
    "toast",
    "notification",
    "dynamic-island",
    "motion"
  ],
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": [
    "*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": {
      "default": "./dist/styles.css"
    }
  },
  "scripts": {
    "build": "bun run styles:generate && tsdown && cp src/styles/ezlet.css dist/styles.css",
    "lint": "biome check .",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "typecheck": "tsc --noEmit",
    "styles:generate": "bun scripts/generate-style-module.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@testing-library/react": "^16.3.0",
    "@types/bun": "latest",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "happy-dom": "^20.10.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsdown": "^0.22.3",
    "typescript": "^5"
  },
  "peerDependencies": {
    "react": "^18.3.0 || ^19.0.0",
    "react-dom": "^18.3.0 || ^19.0.0"
  },
  "dependencies": {
    "motion": "^12.42.0"
  }
}
