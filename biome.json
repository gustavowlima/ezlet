{
  "$schema": "https://biomejs.dev/schemas/2.5.1/schema.json",
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "files": {
    "includes": [
      "packages/ezlet/src/**",
      "packages/ezlet/test/**",
      "packages/ezlet/scripts/**",
      "packages/ezlet/tsdown.config.ts",
      "apps/site/src/**",
      "apps/site/vite.config.ts",
      "apps/site/index.html",
      "apps/site/package.json",
      "*.ts",
      "*.json",
      "*.toml"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 110
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "always"
    }
  },
  "json": {
    "formatter": {
      "indentStyle": "space",
      "lineWidth": 110
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended"
    }
  }
}
